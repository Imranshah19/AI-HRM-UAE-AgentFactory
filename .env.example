# ══════════════════════════════════════════════════════════════════════════════
# AI-HRMS — Environment Variables
# Copy this file to .env and fill in all values before running the project.
# Never commit .env to version control.
# ══════════════════════════════════════════════════════════════════════════════

# ─── Application ──────────────────────────────────────────────────────────────
APP_NAME="AI-HRMS"
APP_ENV=development          # development | staging | production
DEBUG=true
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR | CRITICAL

# ─── URLs ─────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ─── Database (PostgreSQL) ────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://hrms_user:hrms_password@localhost:5432/hrms_db
# Sync URL used only by Alembic migrations
DATABASE_SYNC_URL=postgresql://hrms_user:hrms_password@localhost:5432/hrms_db

POSTGRES_USER=hrms_user
POSTGRES_PASSWORD=hrms_password
POSTGRES_DB=hrms_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Connection pool settings
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=                  # Uncomment and set if Redis auth is enabled

# Celery uses Redis as broker and backend
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ─── Authentication / JWT ─────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_64
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Cookie settings
COOKIE_SECURE=false            # Set to true in production (requires HTTPS)
COOKIE_SAMESITE=lax            # strict | lax | none

# ─── First Super-Admin (created on first startup) ─────────────────────────────
FIRST_SUPERADMIN_EMAIL=admin@hrms.local
FIRST_SUPERADMIN_PASSWORD=Admin@1234!    # Change immediately after first login
FIRST_SUPERADMIN_FIRST_NAME=System
FIRST_SUPERADMIN_LAST_NAME=Admin

# ─── Email (SendGrid) ─────────────────────────────────────────────────────────
SENDGRID_API_KEY=SG.CHANGE_ME
SENDGRID_FROM_EMAIL=noreply@yourcompany.com
SENDGRID_FROM_NAME="AI-HRMS Notifications"

# ─── SMS (Twilio) ─────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TWILIO_AUTH_TOKEN=CHANGE_ME
TWILIO_PHONE_NUMBER=+1234567890

# ─── File Storage ─────────────────────────────────────────────────────────────
# Set STORAGE_BACKEND=local for development, s3 for production
STORAGE_BACKEND=local
LOCAL_UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10

# AWS S3 / S3-Compatible (MinIO, Cloudflare R2, etc.)
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME
AWS_REGION=ap-south-1
AWS_S3_BUCKET=ai-hrms-uploads
# For MinIO or custom endpoint, set this. Leave blank for real AWS S3.
AWS_S3_ENDPOINT_URL=

# ─── AI / OpenAI ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-CHANGE_ME
OPENAI_MODEL=gpt-4o-mini
# Max tokens for HR chatbot responses
OPENAI_MAX_TOKENS=1024

# ─── UAE AI-HRM — Anthropic / Claude ──────────────────────────────────────────
# Required for live Claude AI responses in all 13 UAE LangGraph agents.
# Without this key the system runs in MOCK mode (all endpoints still work).
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# UAE LangGraph agent settings (defaults shown)
UAE_CLAUDE_MODEL=claude-opus-4-7
UAE_CLAUDE_MAX_TOKENS=1024
UAE_AGENT_MODE=mock                     # mock | live  (auto-detected from ANTHROPIC_API_KEY)
UAE_LOG_AGENT_EXECUTIONS=true           # write agent runs to agent_logs_uae table

# ─── UAE — Database URLs (Docker Compose overrides host to "postgres") ─────────
# These match DATABASE_URL / DATABASE_SYNC_URL above.
# Kept here for explicit reference; no need to change separately.
# UAE_DATABASE_URL=postgresql+asyncpg://hrms_user:hrms_password@postgres:5432/hrms_db
# UAE_DATABASE_SYNC_URL=postgresql://hrms_user:hrms_password@postgres:5432/hrms_db

# ─── UAE — Redis / Celery (used by UAE Celery Beat schedules) ─────────────────
# These match REDIS_URL / CELERY_BROKER_URL above.
# Kept here for explicit reference; no need to change separately.
# UAE_REDIS_URL=redis://redis:6379/0
# UAE_CELERY_BROKER_URL=redis://redis:6379/1

# ─── UAE — Compliance Toggles ─────────────────────────────────────────────────
UAE_WPS_DEADLINE_ALERT_DAYS=3           # days before month-end to alert
UAE_DOCUMENT_ALERT_CRITICAL_DAYS=7     # alert tier: CRITICAL
UAE_DOCUMENT_ALERT_URGENT_DAYS=30      # alert tier: URGENT
UAE_DOCUMENT_ALERT_WARNING_DAYS=90     # alert tier: WARNING
UAE_EMIRATISATION_ANNUAL_FINE_AED=96000  # fine per unfilled Emirati slot/yr
UAE_GRATUITY_CAP_MONTHS=24             # max gratuity = 24 months basic salary

# ─── Firebase (Push Notifications — optional) ─────────────────────────────────
# FIREBASE_CREDENTIALS_JSON=./firebase-service-account.json

# ─── Sentry (Error Tracking — optional) ──────────────────────────────────────
# SENTRY_DSN=https://CHANGE_ME@sentry.io/CHANGE_ME

# ─── Multi-Tenancy ────────────────────────────────────────────────────────────
# Default tenant slug used for single-tenant deployments
DEFAULT_TENANT_SLUG=default

# ─── Pagination Defaults ──────────────────────────────────────────────────────
DEFAULT_PAGE_SIZE=25
MAX_PAGE_SIZE=100
