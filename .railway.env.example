# ══════════════════════════════════════════════════════════════════════════════
# AI-HRMS — Railway Environment Variables Reference
# ══════════════════════════════════════════════════════════════════════════════
# Copy the relevant section into each Railway service's "Variables" tab.
# Never commit actual secrets — use Railway's variable management UI.
#
# Railway automatically injects:
#   PORT          → the port your service must listen on
#   RAILWAY_*     → metadata variables (project ID, service name, etc.)
#
# Railway plugins inject (copy the exact variable name from the plugin panel):
#   DATABASE_URL  → from PostgreSQL plugin
#   REDIS_URL     → from Redis plugin
# ══════════════════════════════════════════════════════════════════════════════


# ── BACKEND SERVICE VARIABLES ─────────────────────────────────────────────────

APP_ENV=production
DEBUG=false
LOG_LEVEL=INFO

# Database — copy DATABASE_URL from Railway PostgreSQL plugin, then derive the sync URL:
DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/db
DATABASE_SYNC_URL=postgresql://user:pass@host:5432/db

# Redis — copy REDIS_URL from Railway Redis plugin, then set Celery variants:
REDIS_URL=redis://default:pass@host:6379/0
CELERY_BROKER_URL=redis://default:pass@host:6379/1
CELERY_RESULT_BACKEND=redis://default:pass@host:6379/2

# Auth — generate with: python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET_KEY=CHANGE_ME_min_64_chars_random_hex_string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
COOKIE_SECURE=true
COOKIE_SAMESITE=lax

# URLs — replace with your actual Railway public domains
FRONTEND_URL=https://your-frontend.up.railway.app
BACKEND_URL=https://your-backend.up.railway.app
CORS_ORIGINS=https://your-frontend.up.railway.app

# First super-admin (only used on first boot — change before deploying)
FIRST_SUPERADMIN_EMAIL=admin@yourdomain.com
FIRST_SUPERADMIN_PASSWORD=ChangeMe@1234!
FIRST_SUPERADMIN_FIRST_NAME=System
FIRST_SUPERADMIN_LAST_NAME=Admin

# File storage — set to "s3" if using S3/R2 instead of local disk
STORAGE_BACKEND=local

# S3 / Cloudflare R2 (optional — only needed if STORAGE_BACKEND=s3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_S3_BUCKET=ai-hrms-uploads
AWS_S3_ENDPOINT_URL=

# Email — SendGrid (optional)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
SENDGRID_FROM_NAME=AI-HRMS Notifications

# SMS — Twilio (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# AI — OpenAI (optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini


# ── FRONTEND SERVICE VARIABLES ────────────────────────────────────────────────

NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1
NEXT_PUBLIC_APP_NAME=AI-HRMS

# Public backend URL (used by the browser for client-side API calls)
NEXT_PUBLIC_API_URL=https://your-backend.up.railway.app

# Internal backend URL (used by Next.js server-side rewrites inside Railway's private network)
# Format: http://<backend-service-name>.railway.internal:<port>
# Find your backend's private domain in Railway dashboard → Backend service → Settings → Networking
BACKEND_INTERNAL_URL=http://backend.railway.internal:8000
